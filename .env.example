# ============================================================================
# FITGENIE ENVIRONMENT VARIABLES
# ============================================================================
#
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
#
# For production (Vercel/Firebase Hosting):
# Set these as secret environment variables on your deployment platform.
#
# ============================================================================

# ============================================================================
# GEMINI AI (Client-side, for development/testing ONLY)
# ============================================================================
# WARNING: Client-side API keys are exposed in the browser bundle.
# For production, use server-side proxy via /api/chat or Firebase Functions.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# PRODUCTION / API SECURITY
# ============================================================================

# APP_ORIGIN: The allowed origin for /api/chat requests (CORS)
# Required for production. No wildcard fallback; must be explicit.
# Example: https://fitgenie-x.vercel.app
APP_ORIGIN=http://localhost:3000

# GEMINI_API_KEY: Server-side Gemini API key (backend only)
# Used by /api/chat endpoint to generate AI responses.
# DO NOT set VITE_GEMINI_API_KEY in production (client-side keys are never needed).
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# ANDROID APK DOWNLOAD (for "Download App" button)
# ============================================================================

# VITE_ANDROID_APK_URL: URL to download the signed Android APK
# For production:
#   1. Build APK: npx cap build android
#   2. Sign APK with your keystore (Android Studio / jarsigner)
#   3. Upload to your hosting (Vercel blob storage, Firebase, etc.)
#   4. Set URL here
# Example: https://storage.googleapis.com/your-project/fitgenie-release.apk
# Default (if not set): /fitgenie-latest.apk (served from /public)
VITE_ANDROID_APK_URL=

# VITE_MOBILE_APP_URL: Fallback mobile app store link (iOS App Store, Google Play)
# Used if native install prompt is not available
# Example: https://apps.apple.com/app/fitgenie/id1234567890
VITE_MOBILE_APP_URL=

# ============================================================================
# FIREBASE ADMIN SDK (Server-side quota tracking and auth verification)
# ============================================================================

# FIREBASE_PROJECT_ID: Your Firebase project ID
FIREBASE_PROJECT_ID=your_project_id_here

# FIREBASE_CLIENT_EMAIL: Service account email for firebase-admin
FIREBASE_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com

# FIREBASE_PRIVATE_KEY: Service account private key (newlines as \n)
# Example format: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=your_private_key_here

# ============================================================================
# FIREBASE WEB SDK (Client-side, safe to expose)
# ============================================================================

# VITE_ prefix: Vite exposes these to the client bundle
# These are public API keys; not secrets. Use Firebase security rules + App Check.

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ============================================================================
# FIREBASE APP CHECK (OPTIONAL but RECOMMENDED)
# ============================================================================

# VITE_FIREBASE_APPCHECK_SITE_KEY: reCAPTCHA v3 site key for App Check
# Prevents bot abuse by requiring device verification.
# Leave empty to disable. Set to enable production attestation.
VITE_FIREBASE_APPCHECK_SITE_KEY=
